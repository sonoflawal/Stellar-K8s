{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Stellar-K8s — Advanced Observability Pipeline",
  "uid": "stellar-observability-pipeline",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["stellar", "observability", "anomaly-detection", "rca"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipeline Health",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_pipeline_up",
          "legendFormat": "Pipeline Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Anomalies",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_anomalies_active",
          "legendFormat": "Active Anomalies"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Alerts",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_alerts_active",
          "legendFormat": "Active Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Mean Time to Resolve",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_incident_mttr_seconds",
          "legendFormat": "MTTR"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1800 }, { "color": "red", "value": 3600 }] }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Predictive Alerts",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_predictive_alerts_total",
          "legendFormat": "Predictive Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Open Incidents",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_incidents_open",
          "legendFormat": "Open Incidents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Anomaly Detection Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_anomalies_total[5m])",
          "legendFormat": "Anomaly Rate (5m)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_anomalies_total{anomaly_type=\"Spike\"}[5m])",
          "legendFormat": "Spikes"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_anomalies_total{anomaly_type=\"Drop\"}[5m])",
          "legendFormat": "Drops"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Alert Volume & Deduplication",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_alerts_total[5m])",
          "legendFormat": "New Alerts (5m)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_alerts_deduplicated_total[5m])",
          "legendFormat": "Deduplicated (5m)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_alerts_resolved_total[5m])",
          "legendFormat": "Resolved (5m)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Event Ingestion Rate by Source",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_events_ingested_total{source=\"Metric\"}[1m])",
          "legendFormat": "Metrics"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_events_ingested_total{source=\"Log\"}[1m])",
          "legendFormat": "Logs"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_events_ingested_total{source=\"Trace\"}[1m])",
          "legendFormat": "Traces"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Correlation Engine — Correlations Found",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_correlations_total{type=\"TraceLinked\"}[5m])",
          "legendFormat": "Trace-Linked"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_correlations_total{type=\"Spatial\"}[5m])",
          "legendFormat": "Spatial (same resource)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_correlations_total{type=\"Temporal\"}[5m])",
          "legendFormat": "Temporal"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 30,
      "type": "gauge",
      "title": "RCA Confidence Score",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 6 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizValue": 0, "maxVizValue": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_rca_confidence",
          "legendFormat": "RCA Confidence"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] }
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Incident Timeline — Open vs Resolved",
      "gridPos": { "x": 6, "y": 20, "w": 18, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "stellar_observability_incidents_open",
          "legendFormat": "Open Incidents"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(stellar_observability_incidents_resolved_total[10m])",
          "legendFormat": "Resolution Rate (10m)"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 40,
      "type": "table",
      "title": "Top Anomalous Metrics (Last 1h)",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "options": { "sortBy": [{ "displayName": "Anomaly Count", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by (metric_name, namespace, node_name) (increase(stellar_observability_anomalies_total[1h])))",
          "legendFormat": "{{namespace}}/{{node_name}} — {{metric_name}}",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Anomaly Count" }, { "id": "custom.width", "value": 120 }] }
        ]
      }
    }
  ]
}
